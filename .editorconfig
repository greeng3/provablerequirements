# EditorConfig — baseline conventions across editors. https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Make requires tab-indented recipes.
[Makefile]
indent_style = tab

# YAML conventionally uses 2-space indentation.
[*.{yml,yaml}]
indent_size = 2

# Preserve intentional two-space hard line breaks in Markdown.
[*.md]
trim_trailing_whitespace = false
