# Local-only symlink to the qrusty repo, used purely as a reference for
# dev-environment work. It lives in its own git repo and must never be
# committed from here (it would only store a broken, machine-local link).
/qrusty

# Rust build artifacts. Cargo.lock IS committed (this is a binary crate).
/target

# Frontend. node_modules and Vite build output are generated; only the
# placeholder web/dist/index.html is tracked so bare `cargo build` still
# compiles (rust-embed requires the folder to exist). The real UI is built
# by the pipeline before cargo and embedded at build time.
/web/node_modules
/web/dist/*
!/web/dist/index.html

# macOS noise
.DS_Store

# Claude Code local state (personal; contains credentials) — never commit.
# .claude-home is bind-mounted to /root/.claude in the dev container.
.claude/
.claude-home/
